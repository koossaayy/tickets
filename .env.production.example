# ==========================================================
# Laravel Application
# ==========================================================

APP_NAME="Support Tickets"

APP_ENV=production

APP_KEY=

APP_DEBUG=false

APP_URL=https://support.example.com

# If installed in a subdirectory:
# APP_URL=https://example.com/support

ASSET_URL=https://support.example.com


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US


# ==========================================================
# Logging
# ==========================================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning


# ==========================================================
# Database
# ==========================================================

DB_CONNECTION=mysql

DB_HOST=127.0.0.1

DB_PORT=3306

DB_DATABASE=support_tickets

DB_USERNAME=support_user

DB_PASSWORD=CHANGE_THIS_PASSWORD


# ==========================================================
# Sessions / Cache / Queue
# ==========================================================

SESSION_DRIVER=database

SESSION_LIFETIME=120

SESSION_ENCRYPT=false

SESSION_PATH=/

SESSION_DOMAIN=.example.com


CACHE_STORE=database

QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log


# ==========================================================
# Filesystem
# ==========================================================

FILESYSTEM_DISK=local


# For S3 / Cloud Storage:

AWS_ACCESS_KEY_ID=

AWS_SECRET_ACCESS_KEY=

AWS_DEFAULT_REGION=us-east-1

AWS_BUCKET=

AWS_USE_PATH_STYLE_ENDPOINT=false


# ==========================================================
# Mail Configuration
# ==========================================================
#
# Example using Mailgun SMTP
#

MAIL_MAILER=smtp

MAIL_SCHEME=smtp

MAIL_HOST=smtp.mailgun.org

MAIL_PORT=587

MAIL_USERNAME=postmaster@mg.example.com

MAIL_PASSWORD=CHANGE_THIS_PASSWORD

MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS=support@example.com

MAIL_FROM_NAME="Support Tickets"


# ==========================================================
# Social Login
# ==========================================================
#
# Optional
#

GOOGLE_CLIENT_ID=

GOOGLE_CLIENT_SECRET=


FACEBOOK_CLIENT_ID=

FACEBOOK_CLIENT_SECRET=


# ==========================================================
# Google reCAPTCHA v3
# ==========================================================
#
# Recommended for registration protection
#

RECAPTCHA_SITE_KEY=

RECAPTCHA_SECRET_KEY=

RECAPTCHA_THRESHOLD=0.5


# ==========================================================
# Email Reply Ticket Ingestion
# ==========================================================
#
# Used for:
# reply+token@example.com
#

SUPPORT_REPLY_DOMAIN="example.com"

SUPPORT_MAX_ATTACHMENT_KB=5120


# Used to validate inbound webhook requests

INBOUND_WEBHOOK_SECRET=CHANGE_TO_LONG_RANDOM_SECRET


# ==========================================================
# Livewire
# ==========================================================
#
# Only needed for subdirectory installs
#

# Example:
# https://example.com/support

# APP_URL=https://example.com/support
# ASSET_URL=https://example.com/support


# ==========================================================
# Vite
# ==========================================================

VITE_APP_NAME="${APP_NAME}"